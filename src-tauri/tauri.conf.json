{
  "productName": "evenor",
  "version": "2.5.11",
  "identifier": "com.evenor",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420/",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "evenor",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data:; connect-src 'self' https: http:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "GPLv3",
    "category": "Utilities",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist"
    },
    "iOS": {
      "developmentTeam": "PU6CTXHGJ5"
    }
  },
  "plugins": {}
}
